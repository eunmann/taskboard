# Test environment configuration
# Uses different ports to avoid conflicts with dev services

# Database (test-postgres on port 5433)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_dev
POSTGRES_DB=platform_test
POSTGRES_SSLMODE=disable

# Application
PORT=8080
SITE_URL=http://localhost:8080
LOCAL_AUTH_ENABLED=true
COOKIE_SECURE=false

# AWS (test instances on offset ports)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL_S3=http://localhost:9002
AWS_ENDPOINT_URL_SQS=http://localhost:9326
S3_BUCKET=app-storage

# SQS Queues (test ElasticMQ on port 9326)
TASK_QUEUE_URL=http://localhost:9326/queue/task-queue
TASK_DLQ_URL=http://localhost:9326/queue/task-dlq
EMAIL_QUEUE_URL=http://localhost:9326/queue/email-queue

# Workers
TASK_ENABLED=true
TASK_CONCURRENCY=2
TASK_POLL_INTERVAL=1s

# Email (test MailHog on port 1026)
MAILHOG_HOST=localhost
MAILHOG_SMTP_PORT=1026
MAILHOG_HTTP_PORT=8026
FROM_EMAIL=noreply@localhost

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console

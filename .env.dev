# Development environment configuration
# Loaded by Makefile via load-env helper

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_dev
POSTGRES_DB=platform
POSTGRES_SSLMODE=disable

# Application
PORT=8080
SITE_URL=http://localhost:8080
LOCAL_AUTH_ENABLED=true
COOKIE_SECURE=false

# AWS (local MinIO/ElasticMQ)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL_S3=http://localhost:9000
AWS_ENDPOINT_URL_SQS=http://localhost:9324
S3_BUCKET=app-storage

# SQS Queues
TASK_QUEUE_URL=http://localhost:9324/queue/task-queue
TASK_DLQ_URL=http://localhost:9324/queue/task-dlq
EMAIL_QUEUE_URL=http://localhost:9324/queue/email-queue

# Workers
TASK_ENABLED=true
TASK_CONCURRENCY=4
TASK_POLL_INTERVAL=1s

# Email (MailHog)
MAILHOG_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_HTTP_PORT=8025
FROM_EMAIL=noreply@localhost

# Logging
LOG_LEVEL=debug
LOG_FORMAT=console

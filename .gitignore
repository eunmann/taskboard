*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace sum file
go.work.sum

# Build and coverage artifacts
/artifacts/

# Runtime logs
/logs/
/tmp/

# Code review working files
/review/

# Air hot-reload temp directory
/.air/

# Compiled seed binary
/seed

# Task files created during testing
/.taskboard/
